{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cc-panes",
  "version": "0.9.14",
  "identifier": "com.ccpanes.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:14200",
    "beforeBuildCommand": "cargo build -p cc-panes-hook --release && node scripts/copy-hook.cjs && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CC-Panes",
        "width": 1200,
        "height": 800,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; worker-src 'self' blob:; img-src 'self' asset: http://asset.localhost https://asset.localhost blob: data:; connect-src ipc: http://ipc.localhost http://localhost:*",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/cc-panes-hook*",
      "bundled-claude-config/.claude/commands/ccbook/*",
      "bundled-claude-config/.claude/agents/*",
      "bundled-claude-config/CLAUDE.md"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJEQzBGQzI0NkMyM0ExMzgKUldRNG9TTnNKUHpBdmV3WDM4QUZHOGNZc0VLaFRYVEVZaEZ1ckFSMlh1VVlDQXZtVms3VU5ISGEK",
      "endpoints": [
        "https://github.com/wuxiran/cc-pane/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }

}
